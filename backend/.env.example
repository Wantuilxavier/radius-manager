# ============================================================
# Radius Manager — Variáveis de Ambiente
# Copie este arquivo: cp .env.example .env
# O install.sh preenche este arquivo automaticamente.
# ============================================================

# Servidor
PORT=3000
NODE_ENV=production

# Banco de Dados MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=radius
DB_PASS=SUBSTITUA_PELA_SENHA_GERADA
DB_NAME=radius

# JWT — gere um segredo forte:
# openssl rand -hex 64
JWT_SECRET=SUBSTITUA_POR_UM_SEGREDO_MUITO_FORTE_DE_64_CHARS
JWT_EXPIRES_IN=8h

# CORS
# Em produção, informe o domínio real: https://radius.suaempresa.com
CORS_ORIGIN=*
