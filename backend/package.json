{
  "name": "radius-manager-backend",
  "version": "1.0.0",
  "description": "FreeRADIUS Web Management System",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
